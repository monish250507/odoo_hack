# EcoSphere ESG Management Platform — Environment Configuration

# App
PROJECT_NAME="EcoSphere ESG Management Platform"
ENVIRONMENT=development
DEBUG=True

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ecosphere

# Security
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=11520

# CORS
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]

# AI Subsystem (OpenRouter Gateway)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
CARBON_MODEL=openai/gpt-4o-mini
REPORT_MODEL=openai/gpt-4o-mini
ANOMALY_MODEL=openai/gpt-4o-mini
RECOMMENDATION_MODEL=openai/gpt-4o-mini

# LangSmith Tracing
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=EcoSphere_AI
